#!/usr/bin/make -f

PKGDIR = debian/questlog
SHARE  = $(PKGDIR)/usr/share/questlog

%:
	dh $@

override_dh_auto_build:

override_dh_auto_test:

override_dh_auto_install:
	install -d $(SHARE)/modules $(SHARE)/vendor $(SHARE)/lib $(SHARE)/ui $(SHARE)/cli $(SHARE)/data $(SHARE)/assets
	cp lib/*.tcl $(SHARE)/lib/
	cp ui/*.tcl  $(SHARE)/ui/
	cp cli/*.tcl $(SHARE)/cli/
	cp data/*.csv $(SHARE)/data/
	cp modules/*.tm $(SHARE)/modules/
	cp vendor/*.tm $(SHARE)/vendor/
	cp assets/questlog.svg $(SHARE)/assets/
	install -D -m 0755 questlog $(PKGDIR)/usr/bin/questlog
	sed -i 's|^set ROOT .*|set ROOT /usr/share/questlog|' $(PKGDIR)/usr/bin/questlog
	install -D -m 0644 assets/questlog.desktop \
	    $(PKGDIR)/usr/share/applications/questlog.desktop
	# Icon theme: the .desktop's Icon=questlog resolves here. dh_icons (default
	# dh sequence) adds the update-icon-caches trigger.
	install -D -m 0644 assets/questlog.svg \
	    $(PKGDIR)/usr/share/icons/hicolor/scalable/apps/questlog.svg
	install -D -m 0644 assets/questlog-256.png \
	    $(PKGDIR)/usr/share/icons/hicolor/256x256/apps/questlog.png
	install -D -m 0644 assets/questlog-512.png \
	    $(PKGDIR)/usr/share/icons/hicolor/512x512/apps/questlog.png
