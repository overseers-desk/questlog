#!/usr/bin/env wish9.0
# Claude Session Manager - entry script.

package require Tcl 9
package require Tk

set ROOT [file dirname [file normalize [info script]]]

source [file join $ROOT lib path.tcl]
source [file join $ROOT lib jsonl.tcl]
source [file join $ROOT lib terminal.tcl]
source [file join $ROOT lib live.tcl]
source [file join $ROOT lib scan.tcl]
source [file join $ROOT lib search.tcl]
source [file join $ROOT ui  drag.tcl]
source [file join $ROOT ui  toolbar.tcl]
source [file join $ROOT ui  tree.tcl]
source [file join $ROOT ui  results.tcl]
source [file join $ROOT ui  viewer.tcl]
source [file join $ROOT ui  move_dialog.tcl]
source [file join $ROOT lib app.tcl]

set initial_patterns [list]
for {set i 0} {$i < [llength $argv]} {incr i} {
    set a [lindex $argv $i]
    if {$a eq "-regex" || $a eq "--regex"} {
        incr i
        lappend initial_patterns [lindex $argv $i]
    }
}

::csm::app::start $ROOT $initial_patterns
