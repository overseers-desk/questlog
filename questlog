#!/usr/bin/env wish9.0
# questlog - entry script.

package require Tcl 9

set QUESTLOG_VERSION 1.1.0
if {[lindex $argv 0] in {--version -v}} {
    puts "questlog $QUESTLOG_VERSION"
    exit 0
}

# Detect CLI mode early before Tk starts
set CLI_MODE 0
if {"--json" in $argv || "--cmd" in $argv || "--help" in $argv || "-h" in $argv} {
    set CLI_MODE 1
}

# Hide the root window immediately if Tk was loaded via wish
if {$CLI_MODE && [info commands wm] ne ""} {
    wm withdraw .
}

# Only load GUI packages if NOT in CLI mode
if {!$CLI_MODE} {
    package require Tk
    package require ttk
}

# --font <family|spec> sets the session viewer's reading font. Pulled out of
# argv before the criteria parse so it composes with a criteria chain; applied
# after the theme is initialised.
set VIEWER_FONT ""
set INIT_WINDOW ""
set INIT_SEARCH ""
if {!$CLI_MODE} {
    set kept [list]
    for {set i 0} {$i < [llength $argv]} {incr i} {
        switch -- [lindex $argv $i] {
            --font   { set VIEWER_FONT [lindex $argv [incr i]] }
            --window { set INIT_WINDOW [lindex $argv [incr i]] }
            --search { set INIT_SEARCH [lindex $argv [incr i]] }
            default  { lappend kept [lindex $argv $i] }
        }
    }
    set argv $kept
}

set ROOT [file dirname [file normalize [info script]]]

source [file join $ROOT config.tcl]
source [file join $ROOT lib path.tcl]
source [file join $ROOT lib filter.tcl]
source [file join $ROOT lib state.tcl]
source [file join $ROOT lib jsonl.tcl]
source [file join $ROOT lib match.tcl]
source [file join $ROOT lib scan.tcl]
source [file join $ROOT lib cost.tcl]
source [file join $ROOT lib search.tcl]
source [file join $ROOT lib cli.tcl]
source [file join $ROOT lib cli_mode.tcl]

# In CLI mode, set up matcher caps and execute directly, bypassing the UI completely
if {$CLI_MODE} {
    ::questlog::match::set_caps [dict create \
        content_cap     [::questlog::config::get content_cap] \
        snippet_radius  [::questlog::config::get snippet_radius] \
        tool_param_cap  [::questlog::config::get tool_param_cap] \
        tool_render_cap [::questlog::config::get tool_render_cap]]
    ::questlog::cli_mode::run $argv
    exit 0
}

# Otherwise, load remaining GUI libraries and start GUI application
source [file join $ROOT lib theme.tcl]
source [file join $ROOT lib markdown.tcl]
source [file join $ROOT lib terminal.tcl]
source [file join $ROOT lib live.tcl]
source [file join $ROOT lib title_writer.tcl]
source [file join $ROOT ui  drag.tcl]
source [file join $ROOT ui  toolbar.tcl]
source [file join $ROOT ui  sessions.tcl]
source [file join $ROOT ui  viewer.tcl]
source [file join $ROOT ui  move_dialog.tcl]
source [file join $ROOT lib app.tcl]

# A leading criterion-type token (pattern|read|wrote|edited) launches the GUI
# pre-seeded with that criteria chain; otherwise the -regex flag prefills a
# pattern criterion. Either way the GUI opens normally.
if {[::questlog::cli::is_cli $argv]} {
    set initial_criteria [::questlog::cli::parse $argv]
} else {
    set initial_criteria [list]
    for {set i 0} {$i < [llength $argv]} {incr i} {
        set a [lindex $argv $i]
        if {$a eq "-regex" || $a eq "--regex"} {
            incr i
            lappend initial_criteria \
                [dict create type pattern value [lindex $argv $i]]
        }
    }
}

# The match procs read the display caps from config; inject them once for the
# main interp (each worker gets its own copy via worker_prelude).
::questlog::match::set_caps [dict create \
    content_cap     [::questlog::config::get content_cap] \
    snippet_radius  [::questlog::config::get snippet_radius] \
    tool_param_cap  [::questlog::config::get tool_param_cap] \
    tool_render_cap [::questlog::config::get tool_render_cap]]

::questlog::theme::init
if {$VIEWER_FONT ne ""} { ::questlog::theme::set_body_family $VIEWER_FONT }
::questlog::app::start $ROOT $initial_criteria $INIT_WINDOW $INIT_SEARCH

