#!/usr/bin/env tclsh9.0
# questlog - entry script.

package require Tcl 9

set QUESTLOG_VERSION 1.1.3
if {[lindex $argv 0] in {--version -v}} {
    puts "questlog $QUESTLOG_VERSION"
    exit 0
}

# Detect CLI mode before any library is sourced. The interpreter is tclsh, so
# Tk is absent until a GUI file requires it: CLI mode never loads Tk and runs
# without a display, while GUI mode pulls Tk in through the GUI layer below.
set CLI_MODE 0
if {[lindex $argv 0] in {rename show install-claude-command} \
    || "--json" in $argv || "--cmd" in $argv || "--shortstat" in $argv \
    || "--help" in $argv || "-h" in $argv} {
    set CLI_MODE 1
}

# --font <family|spec> sets the session viewer's reading font. Pulled out of
# argv before the criteria parse so it composes with a criteria chain; applied
# after the theme is initialised.
set VIEWER_FONT ""
set INIT_SINCE ""
set INIT_SEARCH ""
set DEBUG_ENABLED 0
if {!$CLI_MODE} {
    set kept [list]
    for {set i 0} {$i < [llength $argv]} {incr i} {
        switch -- [lindex $argv $i] {
            --font            { set VIEWER_FONT [lindex $argv [incr i]] }
            --since           { set INIT_SINCE [lindex $argv [incr i]] }
            --search          { set INIT_SEARCH [lindex $argv [incr i]] }
            -debug - --debug  { set DEBUG_ENABLED [lindex $argv [incr i]] }
            default           { lappend kept [lindex $argv $i] }
        }
    }
    set argv $kept
}

set ROOT [file dirname [file normalize [info script]]]

# Register questlog with Claude Code. This keeps ~/.claude/commands/questlog.md
# current so a Claude Code session reaches for questlog when the user asks to
# search a past session. It is a system-level install, unrelated to the
# ~/.claude/projects store that lib/path.tcl guards, so it runs here, before any
# library loads, using the native `file` command. The explicit subcommand writes
# with feedback and exits; every other launch silently refreshes the copy.
source [file join $ROOT cli claude_command.tcl]
if {[lindex $argv 0] eq "install-claude-command"} {
    ::questlog::claude::install
    exit 0
}
::questlog::claude::refresh

source [file join $ROOT config.tcl]
source [file join $ROOT lib debug.tcl]
# Carry the parsed -debug value into config so every module reads the gate the
# one way, then bring the diagnostic log up before any module that logs is
# sourced. A failed open inside enable leaves logging off and the run unchanged.
dict set ::questlog::config::Config debug_enabled $DEBUG_ENABLED
if {$DEBUG_ENABLED ne "0" && $DEBUG_ENABLED ne ""} { ::questlog::debug::enable }
source [file join $ROOT lib path.tcl]
source [file join $ROOT lib filter.tcl]
source [file join $ROOT lib jsonl.tcl]
source [file join $ROOT lib match.tcl]
source [file join $ROOT lib scan.tcl]
source [file join $ROOT lib cost.tcl]
source [file join $ROOT lib search.tcl]
source [file join $ROOT lib rename.tcl]
# Headless transcript emitter (the reading view's text mirror). It is Tk-free,
# so it loads in both modes and the GUI's copy/export-markdown actions and the
# CLI `show` subcommand share the one renderer.
source [file join $ROOT lib markdown.tcl]
# In CLI mode, execute directly, bypassing the UI completely. `rename` and
# `show` are standalone file ops (neither needs matcher caps or a cost pass), so
# they dispatch before the search engine's setup.
if {$CLI_MODE} {
    source [file join $ROOT cli main.tcl]
    if {[lindex $argv 0] eq "rename"} {
        ::questlog::cli::main::rename [lrange $argv 1 end]
        exit 0
    }
    if {[lindex $argv 0] eq "show"} {
        ::questlog::cli::main::show [lrange $argv 1 end]
        exit 0
    }
    source [file join $ROOT cli cost.tcl]
    ::questlog::match::set_caps [dict create \
        content_cap     [::questlog::config::get content_cap] \
        snippet_lead    [::questlog::config::get snippet_lead] \
        snippet_trail   [::questlog::config::get snippet_trail] \
        tool_param_cap  [::questlog::config::get tool_param_cap] \
        tool_render_cap [::questlog::config::get tool_render_cap]]
    ::questlog::cli::main::run $argv
    exit 0
}

# GUI mode: source the ui/ layer. Tk (and with it ttk) enters the process here,
# required by theme.tcl (sourced first) and the ui/ classes; the entry script
# never requires Tk itself, so CLI mode above stays Tk-free.
source [file join $ROOT ui  theme.tcl]
source [file join $ROOT ui  terminal.tcl]
source [file join $ROOT ui  live.tcl]
source [file join $ROOT ui  state.tcl]
source [file join $ROOT ui  drag.tcl]
source [file join $ROOT ui  toolbar.tcl]
source [file join $ROOT ui  texttree.tcl]
source [file join $ROOT ui  session_actions.tcl]
source [file join $ROOT ui  sessions.tcl]
source [file join $ROOT ui  viewer.tcl]
source [file join $ROOT ui  move_dialog.tcl]
source [file join $ROOT ui  app.tcl]

# A leading criterion token launches the GUI pre-seeded with that criteria
# chain, in <type> <value> pairs: the file/tool family is tool:<selector>
# (tool:read|write|edit|file <path>, or tool:<name> <key>), and a regex is
# pattern <re>. Otherwise the -regex flag prefills a pattern criterion. Either
# way the GUI opens normally.
set initial_criteria [list]
proc questlog_seed_usage {} {
    puts stderr "usage: questlog <type> <value> \[<type> <value> ...\]"
    puts stderr "  type: tool:read | tool:write | tool:edit | tool:file | tool:<name> | pattern"
    exit 2
}

set first [lindex $argv 0]
if {[llength $argv] > 0 && ([string match tool:* $first] || $first in {pattern regex})} {
    if {[llength $argv] % 2 != 0} { questlog_seed_usage }
    foreach {type value} $argv {
        if {$value eq ""} { questlog_seed_usage }
        if {[string match tool:* $type]} {
            set selector [string range $type [string length "tool:"] end]
            lassign [::questlog::search::tool_selector $selector] kind spec
            if {$kind eq "file"} {
                # The GUI op pill speaks either/read/wrote (wrote = created-or-
                # edited), so the finer write/edit selectors collapse onto wrote.
                set spec [dict getdef {write wrote  edit wrote} $spec $spec]
            }
            lappend initial_criteria [dict create type $kind value [list $spec $value]]
        } elseif {$type in {pattern regex}} {
            lappend initial_criteria [dict create type pattern value $value]
        } else {
            questlog_seed_usage
        }
    }
} else {
    for {set i 0} {$i < [llength $argv]} {incr i} {
        set a [lindex $argv $i]
        if {$a eq "-regex" || $a eq "--regex"} {
            incr i
            lappend initial_criteria \
                [dict create type pattern value [lindex $argv $i]]
        }
    }
}

# The match procs read the display caps from config; inject them once for the
# main interp (each worker gets its own copy via worker_prelude).
::questlog::match::set_caps [dict create \
    content_cap     [::questlog::config::get content_cap] \
    snippet_lead    [::questlog::config::get snippet_lead] \
    snippet_trail   [::questlog::config::get snippet_trail] \
    tool_param_cap  [::questlog::config::get tool_param_cap] \
    tool_render_cap [::questlog::config::get tool_render_cap]]

::questlog::ui::theme::init
if {$VIEWER_FONT ne ""} { ::questlog::ui::theme::set_body_family $VIEWER_FONT }
::questlog::ui::app::start $ROOT $initial_criteria $INIT_SINCE $INIT_SEARCH

