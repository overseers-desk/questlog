#!/usr/bin/env tclsh9.0
# questlog - entry script.
#
# One command line, two answers. cli/commandline.tcl declares it and parses argv
# into a neutral query; `--json` or `--shortstat` prints that query's result and
# exits, and without either the same query seeds the GUI's toolbar and the window
# opens on it. The interpreter is tclsh, so Tk is absent until a GUI file requires it:
# an output flag, `--help`, and the subcommands all answer without a display,
# while the GUI branch pulls Tk in through the ui/ layer.

package require Tcl 9

set QUESTLOG_VERSION 1.1.5
set ROOT [file dirname [file normalize [info script]]]
::tcl::tm::path add $ROOT

# A headless run prints to stdout and raises no window. Tk enters the process
# only through the ui/ layer (every ui/ file requires it), and no headless path
# sources one. Harden that seam: refuse to source any ui/ file, so a GUI source
# mistakenly wired onto a headless path fails loudly here instead of pulling Tk
# in and popping a dialog. The check is a plain string match, independent of the
# `file` wrapper lib/path.tcl installs. The GUI branch never calls this.
proc questlog_forbid_ui {} {
    set ::QL_UI_DIR [file join $::ROOT ui]
    rename source _ql_real_source
    proc source {args} {
        if {[string match $::QL_UI_DIR/* [lindex $args end]]} {
            return -code error "questlog: a headless run will not load the\
                GUI ([lindex $args end])"
        }
        return [uplevel 1 [linsert $args 0 _ql_real_source]]
    }
}

# Registering questlog with Claude Code keeps ~/.claude/commands/questlog.md
# current, so a Claude Code session reaches for questlog when the user asks to
# search a past session. It is a system-level install, unrelated to the
# ~/.claude/projects store that lib/path.tcl guards, so it runs before any
# library loads, using the native `file` command. The explicit subcommand writes
# with feedback and exits; every other launch silently refreshes the copy.
source [file join $ROOT cli claude_command.tcl]
source [file join $ROOT cli commandline.tcl]

set SUBCOMMAND [::questlog::cli::commandline::subcommand_of $argv]
if {$SUBCOMMAND eq "install-claude-command"} {
    ::questlog::claude::install
    exit 0
}
# Asking what questlog is, or which version it is, touches nothing: the refresh
# writes a file under $HOME, so it waits until the command line asks for work.
if {[::questlog::cli::commandline::asks $argv] eq ""} { ::questlog::claude::refresh }

source [file join $ROOT config.tcl]
source [file join $ROOT lib debug.tcl]
source [file join $ROOT lib path.tcl]
source [file join $ROOT lib filter.tcl]
source [file join $ROOT lib sessionlist.tcl]
source [file join $ROOT lib jsonl.tcl]
source [file join $ROOT lib match.tcl]
package require leash
source [file join $ROOT lib scan.tcl]
source [file join $ROOT lib cost.tcl]
source [file join $ROOT lib search.tcl]
source [file join $ROOT lib rename.tcl]
# Headless transcript emitter (the reading view's text mirror). It is Tk-free,
# so it loads for both answers and the GUI's copy/export-markdown actions and
# the `show` subcommand share the one renderer.
source [file join $ROOT lib markdown.tcl]

# `rename` and `show` are standalone file ops - neither is a query, so neither
# needs the grammar, the matcher caps, or a cost pass.
if {$SUBCOMMAND ne ""} {
    questlog_forbid_ui
    source [file join $ROOT cli main.tcl]
    ::questlog::cli::main::$SUBCOMMAND [lrange $argv 1 end]
    exit 0
}

# The query. Parsing calls into lib/search.tcl's region and tool-selector
# vocabulary and lib/filter.tcl's time-spec grammar, so it runs once those are in
# hand, and before either answer is prepared.
set Query [::questlog::cli::commandline::run $argv]

# Bring the diagnostic log up before any module logs. A failed open inside
# enable leaves logging off and the run unchanged.
set QL_DEBUG [dict get $Query debug]
dict set ::questlog::config::Config debug_enabled $QL_DEBUG
if {$QL_DEBUG ne "0" && $QL_DEBUG ne ""} { ::questlog::debug::enable }

# The match procs read the display caps from config; inject them once for this
# interp (each worker gets its own copy via worker_prelude).
::questlog::match::set_caps [dict create \
    content_cap     [::questlog::config::get content_cap] \
    snippet_lead    [::questlog::config::get snippet_lead] \
    snippet_trail   [::questlog::config::get snippet_trail] \
    tool_param_cap  [::questlog::config::get tool_param_cap] \
    tool_render_cap [::questlog::config::get tool_render_cap]]

if {[dict get $Query mode] ne "gui"} {
    questlog_forbid_ui
    source [file join $ROOT cli main.tcl]
    source [file join $ROOT cli cost.tcl]
    ::questlog::cli::main::run $Query
    exit 0
}

# Tk (and with it ttk) enters the process here, required by theme.tcl (sourced
# first) and the ui/ classes; the entry script never requires Tk itself.
source [file join $ROOT ui  theme.tcl]
source [file join $ROOT ui  terminal.tcl]
source [file join $ROOT ui  live.tcl]
source [file join $ROOT ui  state.tcl]
source [file join $ROOT ui  drag.tcl]
source [file join $ROOT ui  toolbar.tcl]
package require streamtree
package require tkdown
source [file join $ROOT ui  session_actions.tcl]
source [file join $ROOT ui  sessions.tcl]
source [file join $ROOT ui  viewer.tcl]
source [file join $ROOT ui  move_dialog.tcl]
source [file join $ROOT ui  app.tcl]

# Turn the query into the toolbar's own vocabulary: keywords are the search
# field's text (its grammar splits on space and quotes a phrase), a regex is a
# pattern criterion, and a tool clause is a file or tool criterion. The op pill
# reads either/read/wrote, so the finer write and edit selectors collapse onto
# wrote. The grammar has already refused every clause with no widget behind it,
# so each clause below has somewhere to land.
proc questlog_seed {q} {
    set criteria [list]
    set terms [list]
    foreach c [concat {*}[dict get $q groups]] {
        set val [dict get $c value]
        switch -- [dict get $c kind] {
            keyword {
                lappend terms [expr {[regexp {\s} $val] ? "\"$val\"" : $val}]
            }
            regex { lappend criteria [list pattern $val] }
            tool {
                set spec [dict get $c selspec]
                if {[dict get $c selkind] eq "file"} {
                    set spec [dict getdef {write wrote  edit wrote} $spec $spec]
                }
                lappend criteria [list [dict get $c selkind] [list $spec $val]]
            }
        }
    }
    if {[dict get $q subtree] ne ""} {
        lappend criteria [list subtree [dict get $q subtree]]
    }
    return [dict create criteria $criteria search [join $terms " "] \
        since [dict get $q since] case [expr {![dict get $q nocase]}]]
}

::questlog::ui::theme::init
if {[dict get $Query font] ne ""} {
    ::questlog::ui::theme::set_body_family [dict get $Query font]
}
::questlog::ui::app::start $ROOT [questlog_seed $Query]
